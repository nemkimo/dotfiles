{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["./instructions/*.md"],
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "sort *": "allow"
    },
    "edit": "deny",
    "glob": "allow",
    "grep": "allow",
    "question": "allow",
    "read": "allow",
    "todowrite": "allow"
  },
  "agent": {
    "build": {
      "permission": {
        "edit": "ask"
      }
    }
  }
}
